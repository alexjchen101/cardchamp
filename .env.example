# CoPilot API Credentials - PRODUCTION
# Get these from CardConnect/Fiserv

# Authentication endpoint (PRODUCTION)
COPILOT_AUTH_URL=https://accounts.cardconnect.com/auth/realms/cardconnect/protocol/openid-connect/token

# API endpoint (PRODUCTION)
COPILOT_API_URL=https://api.cardconnect.com

# Your credentials
COPILOT_CLIENT_ID=your_client_id
COPILOT_CLIENT_SECRET=your_client_secret
COPILOT_USERNAME=your_username
COPILOT_PASSWORD=your_password

# Your template and sales code
COPILOT_TEMPLATE_ID=your_template_id
COPILOT_SALES_CODE=your_sales_code

# HubSpot API Credentials
# Get from: Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=pat-na1-your-access-token-here
